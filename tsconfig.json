{
    "compilerOptions": {
        "target": "es2015",
        "module": "Node16",
        "moduleResolution": "node16",
        "rootDir": "src",
        "declaration": true, //自动生成 type 类型声明文件
        "declarationDir": "dist/typing",
        "strict": true,
        "sourceMap": false,
        "noImplicitAny": false,
        "types": [],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "experimentalDecorators": true,
        "lib": ["ES2015", "DOM"]
    },
    "exclude": ["dist"]
}
